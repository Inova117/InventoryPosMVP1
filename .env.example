# Demo mode (muestra la barra de bienvenida y los datos de ejemplo)
# Ponlo en "false" para ocultar la barra de demo.
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (no requerido para la demo: la app usa un mock-db en localStorage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry (opcional)
NEXT_PUBLIC_SENTRY_DSN=
